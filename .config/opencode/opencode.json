{
  "$schema": "https://opencode.ai/config.json",

  "permission": {
    "read": {
      "*": "ask"
    },
    "skill": {
      "*": "allow"
    }
  },

  "mcp": {
    "context7": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "YOUR_API_KEY_HERE"
      }
    }
  }
}
