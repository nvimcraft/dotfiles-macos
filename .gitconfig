[includeIf "gitdir:/Users/rjleyva/Developer/projects/gitea/"]
  path = /Users/rjleyva/.gitconfig-gitea
[includeIf "gitdir:/Users/rjleyva/Developer/projects/github/"]
  path = /Users/rjleyva/.gitconfig-github

[core]
  pager = delta
	excludesfile = /Users/rjl/.gitignore_global
  editor = nvim

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  side-by-side = true

[merge]
  conflictstyle = diff3

[diff]
    colorMoved = default

[init]
	defaultBranch = main

[pull]
	rebase = false
